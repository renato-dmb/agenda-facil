{
  "name": "agenda-facil",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS multi-tenant de agente IA para profissionais liberais via WhatsApp",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bot:dev": "pnpm --filter @agenda-facil/bot dev",
    "bot:start": "pnpm --filter @agenda-facil/bot start",
    "bot:seed": "pnpm --filter @agenda-facil/bot seed",
    "bot:oauth": "pnpm --filter @agenda-facil/bot oauth",
    "bot:pair": "pnpm --filter @agenda-facil/bot pair",
    "db:migrate": "pnpm --filter @agenda-facil/db migrate",
    "dashboard:dev": "pnpm --filter @agenda-facil/dashboard dev",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:migrate": "TEST_DATABASE_URL=postgres://test:test@localhost:5433/agenda_facil_test node scripts/setup-test-db.js",
    "test:unit": "pnpm -r --filter='./packages/**' --filter='./apps/bot' run test:unit",
    "test:integration": "pnpm --filter @agenda-facil/bot run test:integration",
    "test:e2e:dashboard": "pnpm --filter @agenda-facil/dashboard run test:e2e",
    "test:e2e:bot": "pnpm --filter @agenda-facil/bot run test:e2e",
    "test:all": "pnpm test:db:up && pnpm test:db:migrate && pnpm test:unit && pnpm test:integration && pnpm test:e2e:bot && pnpm test:e2e:dashboard"
  },
  "devDependencies": {
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
