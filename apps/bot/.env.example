# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agenda_facil

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Calendar OAuth (1 app, usado por todos os tenants — cada tenant autoriza sua própria conta)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/google/callback

# HTTP
PORT=3001
NODE_ENV=development

# Timezone default aplicado a tenants sem timezone explícito
DEFAULT_TIMEZONE=America/Sao_Paulo

# Log
LOG_LEVEL=info
